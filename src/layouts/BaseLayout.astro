---
import "../styles/global.css";
import SiteNav from "../components/SiteNav.astro";
import TrailMap from "../components/TrailMap.astro";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description = "Following Val and Keith's journey along the historic Oregon Trail — St. Louis to Oregon.", ogImage } = Astro.props;
const siteTitle = "The Oregon Trail Journal";
const fullTitle = title === siteTitle ? title : `${title} — ${siteTitle}`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const defaultOgImage = new URL("/images/day-20/IMG_6187.jpeg", Astro.site);
const ogImageURL = ogImage ? new URL(ogImage, Astro.site) : defaultOgImage;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!-- Google tag (gtag.js) -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-J12MCNYBF6"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-J12MCNYBF6');
    </script>
    <link rel="canonical" href={canonicalURL} />
    <meta name="description" content={description} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{fullTitle}</title>
  </head>
  <body>
    <SiteNav />

    <slot />

    <footer class="site-footer">

      <!-- Trail map -->
      <div class="footer-map-wrap" id="trail-map">
        <TrailMap />
      </div>

      <!-- Footer columns -->
      <div class="footer-body">
        <div class="footer-inner">

          <!-- Community links -->
          <div class="footer-col">
            <h4 class="footer-col__heading">Our Community</h4>
            <ul class="footer-links">
              <li>
                <a
                  href="https://airstreamclub.org/carolinas"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="footer-link"
                >Carolinas Airstream Club</a>
              </li>
              <li>
                <a
                  href="https://www.bluecompassrv.com/"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="footer-link"
                >Blue Compass RV &middot; Greensboro, NC</a>
              </li>
            </ul>
          </div>

          <!-- Upcoming event -->
          <div class="footer-col">
            <h4 class="footer-col__heading">Upcoming</h4>
            <div class="footer-event">
              <svg class="footer-event__wheel" viewBox="0 0 36 36" aria-hidden="true">
                <circle cx="18" cy="18" r="3.5" fill="none" stroke="currentColor" stroke-width="1.5"/>
                <circle cx="18" cy="18" r="15" fill="none" stroke="currentColor" stroke-width="1.5"/>
                <line x1="18" y1="3" x2="18" y2="33" stroke="currentColor" stroke-width="1"/>
                <line x1="3"  y1="18" x2="33" y2="18" stroke="currentColor" stroke-width="1"/>
                <line x1="7.6" y1="7.6" x2="28.4" y2="28.4" stroke="currentColor" stroke-width="1"/>
                <line x1="28.4" y1="7.6" x2="7.6" y2="28.4" stroke="currentColor" stroke-width="1"/>
              </svg>
              <div class="footer-event__content">
                <div class="footer-event__eyebrow">April 2027</div>
                <div class="footer-event__title">Wagon Wheel</div>
                <div class="footer-event__detail">
                  Edward Franklin House<br />
                  Carolinas Airstream Club
                </div>
              </div>
            </div>
          </div>

          <!-- About -->
          <div class="footer-col footer-col--about">
            <p>Val &amp; Keith are following the historic Oregon Trail from St.&nbsp;Louis to Oregon in their Airstream &mdash; 2026.</p>
            <p class="footer-copy">&copy; 2026 Val &amp; Keith</p>
          </div>

        </div>
      </div>

    </footer>

    <!-- Lightbox -->
    <div class="lightbox" id="lightbox" role="dialog" aria-modal="true" aria-label="Photo viewer">
      <button class="lightbox__close" id="lightbox-close" aria-label="Close">&times;</button>
      <img class="lightbox__img" id="lightbox-img" src="" alt="" />
    </div>

    <script>
      const lightbox = document.getElementById("lightbox")!;
      const lightboxImg = document.getElementById("lightbox-img") as HTMLImageElement;
      const lightboxClose = document.getElementById("lightbox-close")!;

      document.querySelectorAll(".photo-grid__item img").forEach((img) => {
        img.addEventListener("click", () => {
          lightboxImg.src = (img as HTMLImageElement).src;
          lightboxImg.alt = (img as HTMLImageElement).alt;
          lightbox.classList.add("is-open");
          document.body.style.overflow = "hidden";
        });
      });

      function closeLightbox() {
        lightbox.classList.remove("is-open");
        document.body.style.overflow = "";
      }

      lightboxClose.addEventListener("click", closeLightbox);
      lightbox.addEventListener("click", (e) => {
        if (e.target === lightbox) closeLightbox();
      });
      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") closeLightbox();
      });
    </script>
  </body>
</html>
