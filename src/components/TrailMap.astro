<div id="footer-trail-map" class="footer-trail-map" aria-label="Map showing Val and Keith's Oregon Trail route"></div>

<script is:inline define:vars={{ routeData, futureRouteData, upcomingStopsData, stopsData, visitedData, airstreamIconHtml }}>
(function () {
  const route         = JSON.parse(routeData);
  const futureRoute   = JSON.parse(futureRouteData);
  const upcomingStops = JSON.parse(upcomingStopsData);
  const stops         = JSON.parse(stopsData);
  const visitedFIPS   = new Set(JSON.parse(visitedData));

  /* ── load CSS ── */
  const css = document.createElement("link");
  css.rel  = "stylesheet";
  css.href = "https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.css";
  document.head.appendChild(css);

  /* ── sequential script loader ── */
  function seq(srcs, cb) {
    if (!srcs.length) return cb();
    const s = document.createElement("script");
    s.src    = srcs[0];
    s.onload = () => seq(srcs.slice(1), cb);
    document.head.appendChild(s);
  }

  seq([
    "https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.js",
    "https://cdn.jsdelivr.net/npm/topojson-client@3/dist/topojson-client.min.js",
  ], function() {
    // Wait until the container has a real height (global.css may still be applying)
    function waitAndInit(tries) {
      const el = document.getElementById("footer-trail-map");
      if (el && el.offsetHeight > 0) { init(el); return; }
      if (tries > 0) setTimeout(function() { waitAndInit(tries - 1); }, 80);
    }
    waitAndInit(20);
  });

  function init(el) {
    if (!el) return;

    const map = L.map(el, {
      scrollWheelZoom: false,
      zoomControl:     false,
      attributionControl: true,
    });
    map.attributionControl.setPrefix(false);

    /* ── CartoDB Positron — clean minimal base ── */
    L.tileLayer(
      "https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png",
      {
        attribution:
          '© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> © <a href="https://carto.com/">CARTO</a>',
        subdomains: "abcd",
        maxZoom: 20,
      }
    ).addTo(map);

    /* ── fit to trail; mobile gets a closer view of the current segment ── */
    const isCompact = window.matchMedia("(max-width: 600px)").matches;
    const recentStopPts = stops.slice(-5).map((s) => [s.lat, s.lon]);
    const nextStopPts = upcomingStops.slice(0, 1).map((s) => [s.lat, s.lon]);
    const allPts = [...route, ...futureRoute.slice(1)];
    const initialPts = isCompact ? [...recentStopPts, ...nextStopPts] : allPts;
    map.fitBounds(initialPts, {
      padding: isCompact ? [22, 22] : [28, 42],
      maxZoom: isCompact ? 7 : undefined,
    });

    /* ── US state boundaries + visited highlights via topojson ── */
    fetch("https://cdn.jsdelivr.net/npm/us-atlas@3/states-10m.json")
      .then((r) => r.json())
      .then((us) => {
        const geojson = topojson.feature(us, us.objects.states);
        L.geoJSON(geojson, {
          style: (feature) => {
            const id       = Number(feature.id);
            const isVisited = visitedFIPS.has(id);
            return {
              fillColor:   isVisited ? "#c8892a" : "transparent",
              fillOpacity: isVisited ? 0.22 : 0,
              color:       isVisited ? "#c8892a" : "#ccc5bb",
              weight:      isVisited ? 1.5 : 0.5,
            };
          },
        }).addTo(map);

        drawTrail();
      })
      .catch(() => drawTrail()); // draw trail even if GeoJSON fails

    function stopTip(s) {
      return `Day ${s.day} · ${s.label}`;
    }

    function linkStop(layer, s) {
      layer
        .bindTooltip(stopTip(s), { direction: "top", offset: [0, -8] })
        .on("click", () => { window.location.href = s.href; });
      layer.addTo(map);
    }

    function drawTrail() {
      /* traveled line — I-81 → I-64 → I-70 corridor */
      L.polyline(route, {
        color:     "#7a5c3a",
        weight:    3,
        dashArray: "9, 5",
        lineCap:   "round",
        lineJoin:  "round",
      }).addTo(map);

      /* upcoming route — current camp to Oregon City */
      L.polyline(futureRoute, {
        color:     "#7a5c3a",
        weight:    2,
        dashArray: "4, 10",
        opacity:   0.35,
      }).addTo(map);

      /* upcoming stop dots */
      upcomingStops.forEach((s) => {
        const tip = s.isNext ? `Next · ${s.label}` : s.label;
        L.circleMarker([s.lat, s.lon], {
          radius:      s.isNext ? 6 : 4,
          fillColor:   s.isNext ? "#f5efe3" : "transparent",
          color:       "#7a5c3a",
          weight:      s.isNext ? 2.5 : 1.5,
          fillOpacity: s.isNext ? 1 : 0,
          opacity:     s.isNext ? 1 : 0.55,
          className:   s.isNext ? "tm-upcoming tm-upcoming--next" : "tm-upcoming",
        })
          .bindTooltip(tip, { direction: "top", offset: [0, -8] })
          .addTo(map);
      });

      /* intermediate stop dots */
      stops.slice(1, -1).forEach((s) => {
        linkStop(
          L.circleMarker([s.lat, s.lon], {
            radius:      5,
            fillColor:   "#c8892a",
            color:       "#fff",
            weight:      1.5,
            fillOpacity: 1,
            className:   "tm-stop",
          }),
          s
        );
      });

      /* HOME marker */
      const home = stops[0];
      const homeMarker = L.marker([home.lat, home.lon], {
        icon: L.divIcon({
          className: "tm-clickable",
          html: '<div class="tm-marker tm-marker--home">⌂</div>',
          iconSize:   [30, 30],
          iconAnchor: [15, 15],
        }),
      });
      homeMarker
        .bindTooltip(stopTip(home), { direction: "top" })
        .on("click", () => { window.location.href = home.href; })
        .addTo(map);

      /* current position — Airstream marker */
      const cur = stops[stops.length - 1];
      const curMarker = L.marker([cur.lat, cur.lon], {
        icon: L.divIcon({
          className: "tm-clickable",
          html: airstreamIconHtml,
          iconSize:   [44, 22],
          iconAnchor: [22, 22],
        }),
      });
      curMarker
        .bindTooltip(stopTip(cur), {
          permanent:  true,
          direction:  "top",
          offset:     [0, -30],
          className:  "tm-tooltip tm-tooltip--current",
        })
        .on("click", () => { window.location.href = cur.href; })
        .addTo(map);
    }
  }
})();
</script>

<style>
  .footer-trail-map {
    height: 380px;
    width: 100%;
    background: #f4ede0;
  }

  @media (max-width: 600px) {
    .footer-trail-map { height: 260px; }
  }

  /* Clickable stops */
  :global(.tm-clickable),
  :global(.tm-stop) {
    cursor: pointer;
  }

  :global(.tm-upcoming) {
    cursor: default;
  }

  /* Custom markers */
  :global(.tm-marker) {
    width: 30px;
    height: 30px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 2px 8px rgba(0,0,0,.28);
  }
  :global(.tm-marker--home) {
    background: #7a5c3a;
    color: #f5efe3;
    font-size: 15px;
    border: 2px solid #f5efe3;
  }

  :global(.tm-airstream) {
    position: relative;
    width: 44px;
    height: 22px;
    filter: drop-shadow(0 2px 5px rgba(0, 0, 0, 0.32));
  }
  :global(.tm-airstream svg) {
    display: block;
    width: 100%;
    height: 100%;
    position: relative;
    z-index: 1;
    transform: scaleX(-1); /* westbound */
  }
  :global(.tm-airstream__pulse) {
    position: absolute;
    left: 50%;
    bottom: 1px;
    width: 14px;
    height: 14px;
    margin-left: -7px;
    border-radius: 50%;
    border: 2px solid rgba(200, 137, 42, 0.65);
    animation: tm-pulse 2.6s ease-out infinite;
    z-index: 0;
    pointer-events: none;
  }
  @keyframes tm-pulse {
    0%   { transform: scale(1);   opacity: .8; }
    100% { transform: scale(3.2); opacity: 0;  }
  }

  /* Tooltip */
  :global(.tm-tooltip) {
    background: #3d2a18 !important;
    border: none !important;
    border-radius: 4px !important;
    color: #f0e8dc !important;
    font-family: 'Source Sans 3', system-ui, sans-serif !important;
    font-size: 11px !important;
    font-weight: 600 !important;
    padding: 3px 8px !important;
    white-space: nowrap !important;
    box-shadow: 0 2px 8px rgba(0,0,0,.35) !important;
  }
  :global(.tm-tooltip::before) { border-top-color: #3d2a18 !important; }

  /* Leaflet chrome tweaks */
  :global(.leaflet-container) {
    font-family: 'Source Sans 3', system-ui, sans-serif;
    border-radius: var(--radius-md, 8px) var(--radius-md, 8px) 0 0;
  }
  :global(.leaflet-control-attribution) {
    font-size: 9px !important;
    background: rgba(244,237,224,.8) !important;
    color: #9e8e7c !important;
  }
  :global(.leaflet-control-attribution a) { color: #7a5c3a !important; }
  :global(.leaflet-tooltip) {
    background: rgba(61,42,24,.85);
    border-color: transparent;
    color: #f0e8dc;
    font-size: 11px;
    font-family: 'Source Sans 3', system-ui, sans-serif;
    padding: 3px 8px;
    border-radius: 4px;
    box-shadow: 0 2px 8px rgba(0,0,0,.25);
  }
  :global(.leaflet-tooltip::before) { border-top-color: rgba(61,42,24,.85); }
</style>
