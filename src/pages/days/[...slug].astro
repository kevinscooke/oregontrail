---
import { getCollection, render } from "astro:content";
import DayLayout from "../../layouts/DayLayout.astro";
import { entrySlug } from "../../utils/slug";

export async function getStaticPaths() {
  const allDays = await getCollection("days");
  const sorted = allDays.sort((a, b) => a.data.day - b.data.day);

  return sorted.map((entry, i) => ({
    params: { slug: entrySlug(entry.id) },
    props: {
      entry,
      prev: sorted[i - 1] ?? null,
      next: sorted[i + 1] ?? null,
    },
  }));
}

const { entry, prev, next } = Astro.props;
const { Content } = await render(entry);
---

<DayLayout entry={entry} prev={prev ?? undefined} next={next ?? undefined}>
  <Content />
</DayLayout>
